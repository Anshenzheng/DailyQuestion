page {
  background-color: #FFF8F3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.warm-bg {
  background-color: #FFF8F3;
}

.warm-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.08);
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.warm-btn {
  background: linear-gradient(135deg, #FF8C42 0%, #FFA85A 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 24rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.warm-btn:active {
  opacity: 0.8;
}

.warm-btn-outline {
  background-color: transparent;
  color: #FF8C42;
  border: 2rpx solid #FF8C42;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 22rpx 46rpx;
}

.text-center {
  text-align: center;
}

.text-primary {
  color: #FF8C42;
}

.text-secondary {
  color: #999999;
}

.text-muted {
  color: #CCCCCC;
}

.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.p-32 { padding: 32rpx; }

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
