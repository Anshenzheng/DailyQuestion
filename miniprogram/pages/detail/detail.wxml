<view class="detail-container">
  <view class="date-section warm-card">
    <view class="date-display">
      <text class="day">{{day}}</text>
      <view class="date-info">
        <text class="month-year">{{monthYear}}</text>
        <text class="weekday">{{weekday}}</text>
      </view>
    </view>
    <view class="check-badge">
      <text class="check-icon">✓</text>
    </view>
  </view>

  <view class="question-section warm-card">
    <view class="section-header">
      <text class="section-title">当日问题</text>
    </view>
    <text class="question-content">{{answer.questionContent}}</text>
  </view>

  <view class="answer-section warm-card">
    <view class="section-header">
      <text class="section-title">我的回答</text>
      <text class="answer-time">{{answerTime}}</text>
    </view>
    
    <view class="answer-content-wrapper" wx:if="{{answer.content}}">
      <text class="answer-content">{{answer.content}}</text>
    </view>
    
    <view class="answer-image-wrapper" wx:if="{{answer.imageUrl}}">
      <image 
        class="answer-image" 
        src="{{answer.imageUrl}}" 
        mode="aspectFill"
        bindtap="previewImage"
        data-url="{{answer.imageUrl}}"
      ></image>
    </view>

    <view class="empty-answer" wx:if="{{!answer.content && !answer.imageUrl}}">
      <text class="empty-text">暂无文字回答</text>
    </view>
  </view>

  <view class="share-section">
    <button class="share-btn warm-btn-outline" open-type="share">
      分享这一天
    </button>
  </view>
</view>
