.detail-container {
  min-height: 100vh;
  background-color: #FFF8F3;
  padding: 32rpx;
  padding-bottom: 60rpx;
}

.date-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5EB 100%);
}

.date-display {
  display: flex;
  align-items: center;
}

.day {
  font-size: 72rpx;
  font-weight: 500;
  color: #FF8C42;
  margin-right: 24rpx;
}

.date-info {
  display: flex;
  flex-direction: column;
}

.month-year {
  font-size: 28rpx;
  color: #333333;
}

.weekday {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.check-badge {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFA85A 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #FF8C42;
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #FF8C42 0%, #FFA85A 100%);
  border-radius: 3rpx;
}

.question-content {
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.8;
  display: block;
}

.answer-time {
  font-size: 24rpx;
  color: #999999;
}

.answer-content-wrapper {
  padding: 24rpx;
  background-color: #FFF8F3;
  border-radius: 16rpx;
}

.answer-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 2;
  display: block;
}

.answer-image-wrapper {
  margin-top: 24rpx;
}

.answer-image {
  width: 100%;
  min-height: 400rpx;
  max-height: 600rpx;
  border-radius: 16rpx;
}

.empty-answer {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #CCCCCC;
}

.share-section {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.share-btn {
  min-width: 280rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
}

.share-btn::after {
  border: none;
}
