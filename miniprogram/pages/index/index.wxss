.index-container {
  min-height: 100vh;
  background-color: #FFF8F3;
  padding: 32rpx;
  padding-bottom: 60rpx;
}

.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.date-info {
  display: flex;
  flex-direction: column;
}

.weekday {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
}

.date {
  font-size: 26rpx;
  color: #999999;
  margin-top: 4rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE8D8;
}

.question-section {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5EB 100%);
}

.loading-card {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200rpx;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.question-label {
  font-size: 24rpx;
  color: #FF8C42;
  background-color: #FFF0E5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.question-category {
  font-size: 24rpx;
  color: #999999;
}

.question-content {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.6;
  display: block;
}

.answer-section {
  position: relative;
}

.answer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.answer-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.answer-count {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFA85A 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.answer-text-section {
  margin-bottom: 24rpx;
}

.answer-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
}

.answer-image-section {
  margin-bottom: 24rpx;
}

.answer-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
}

.answer-form {
  display: flex;
  flex-direction: column;
}

.answer-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333333;
  padding: 20rpx;
  background-color: #FFF8F3;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.answer-image-preview {
  margin-bottom: 24rpx;
}

.image-wrapper {
  position: relative;
  display: inline-block;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 32rpx;
  color: #FFFFFF;
}

.answer-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upload-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #FFF5EB;
  border-radius: 40rpx;
}

.upload-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #FF8C42;
}

.submit-btn {
  min-width: 200rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.edit-btn {
  min-width: 200rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.edit-btn::after {
  border: none;
}

.tips-section {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #CCCCCC;
}
