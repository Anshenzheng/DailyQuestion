.history-container {
  min-height: 100vh;
  background-color: #FFF8F3;
  padding: 32rpx;
  padding-bottom: 60rpx;
}

.header-section {
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  position: relative;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.date-info {
  display: flex;
  align-items: center;
}

.day {
  font-size: 48rpx;
  font-weight: 500;
  color: #FF8C42;
  margin-right: 16rpx;
}

.date-text {
  display: flex;
  flex-direction: column;
}

.month {
  font-size: 24rpx;
  color: #999999;
}

.weekday {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.check-badge {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #FF8C42 0%, #FFA85A 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.question-section {
  padding: 20rpx;
  background-color: #FFF8F3;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.question-label {
  font-size: 22rpx;
  color: #FF8C42;
  display: block;
  margin-bottom: 8rpx;
}

.question-content {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.6;
  display: block;
}

.answer-section {
  padding: 20rpx;
  background-color: #FAFAFA;
  border-radius: 16rpx;
}

.answer-text-wrapper {
  margin-bottom: 16rpx;
}

.answer-label {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.answer-content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.answer-image-wrapper {
  margin-top: 16rpx;
}

.answer-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.item-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

.empty-state {
  margin-top: 40rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

.start-btn {
  min-width: 240rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 40rpx;
}

.start-btn::after {
  border: none;
}
