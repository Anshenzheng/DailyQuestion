<view class="history-container">
  <view class="header-section">
    <text class="title">历史记录</text>
    <text class="subtitle">回顾你的美好回忆</text>
  </view>

  <view class="history-list" wx:if="{{historyList.length > 0}}">
    <view 
      class="history-item warm-card" 
      wx:for="{{historyList}}" 
      wx:key="id"
      bindtap="viewDetail"
      data-id="{{item.id}}"
    >
      <view class="item-header">
        <view class="date-info">
          <text class="day">{{item.day}}</text>
          <view class="date-text">
            <text class="month">{{item.month}}月</text>
            <text class="weekday">{{item.weekday}}</text>
          </view>
        </view>
        <view class="check-badge" wx:if="{{item.hasAnswered}}">
          <text class="check-icon">✓</text>
        </view>
      </view>

      <view class="question-section">
        <text class="question-label">当日问题</text>
        <text class="question-content">{{item.questionContent}}</text>
      </view>

      <view class="answer-section" wx:if="{{item.content || item.imageUrl}}">
        <view class="answer-text-wrapper" wx:if="{{item.content}}">
          <text class="answer-label">我的回答</text>
          <text class="answer-content">{{item.content}}</text>
        </view>
        <view class="answer-image-wrapper" wx:if="{{item.imageUrl}}">
          <image class="answer-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        </view>
      </view>

      <view class="item-footer">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="empty-state warm-card" wx:else>
    <view class="empty-content">
      <text class="empty-icon">📝</text>
      <text class="empty-title">暂无历史记录</text>
      <text class="empty-desc">开始记录你的每一天，</text>
      <text class="empty-desc">让回忆变得更加美好</text>
      <button class="start-btn warm-btn" bindtap="goToToday">
        开始记录
      </button>
    </view>
  </view>
</view>
